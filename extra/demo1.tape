Output demo1.gif
Set FontSize 14
Set Width 1920
Set Height 1080

Hide
Type "export PS1='demo ~ $ '"
Enter
Ctrl+L
Show

Type "scylla-reader"
Enter
Sleep 2s

# open insert modal
Type "i"
Sleep 500ms

# type into the field
Type "https://www.royalroad.com/fiction/117255/rend"
Sleep 500ms

# submit
Ctrl+S
Sleep 1s

#past template
Down
Sleep 1s

# enter the created item
Enter
Sleep 2s
